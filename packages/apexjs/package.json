{
  "name": "@apex-stack/core",
  "version": "0.27.1",
  "description": "The full-stack meta-framework for Alpine.js — CLI and runtime",
  "type": "module",
  "license": "MIT",
  "author": "Andre Corugda",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrecorugda/apexjs.git",
    "directory": "packages/apexjs"
  },
  "homepage": "https://apexjs.site",
  "bugs": {
    "url": "https://github.com/andrecorugda/apexjs/issues"
  },
  "keywords": [
    "alpine",
    "alpinejs",
    "framework",
    "ssr",
    "apex",
    "apexjs"
  ],
  "bin": {
    "apex": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "templates",
    "vscode",
    "components"
  ],
  "scripts": {
    "build": "node scripts/copy-templates.mjs && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "citty": "^0.2.2",
    "h3": "^1.13.0",
    "vite": "^7.0.0",
    "zod": "^4.4.3",
    "@apex-stack/kit": "workspace:*",
    "@apex-stack/vite": "workspace:*",
    "@apex-stack/theme": "workspace:*"
  },
  "peerDependencies": {
    "alpinejs": "^3.14.0"
  },
  "engines": {
    "node": ">=20.19"
  },
  "sideEffects": false
}
