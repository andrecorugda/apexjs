{
  "name": "@apex-stack/theme",
  "version": "0.3.0",
  "description": "Theme tokens + Tailwind preset for Apex JS — one theme, inherited by every component",
  "type": "module",
  "license": "MIT",
  "author": "Andre Corugda",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrecorugda/apexjs.git",
    "directory": "packages/theme"
  },
  "homepage": "https://apexjs.site",
  "bugs": {
    "url": "https://github.com/andrecorugda/apexjs/issues"
  },
  "keywords": ["alpine", "alpinejs", "tailwind", "theme", "design-tokens", "apex", "apexjs"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": "./theme.css"
  },
  "files": ["dist", "theme.css", "NOTICE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.19"
  }
}
