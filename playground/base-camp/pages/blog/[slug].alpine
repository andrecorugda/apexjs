<script server lang="ts">
  export function loader({ params }: { params: Record<string, string> }) {
    return { slug: params.slug }
  }
</script>

<template x-data>
  <main>
    <h1 x-text="'Post: ' + slug"></h1>
    <p>Dynamic route from <code>pages/blog/[slug].alpine</code>.</p>
    <a href="/">← Home</a>
  </main>
</template>

