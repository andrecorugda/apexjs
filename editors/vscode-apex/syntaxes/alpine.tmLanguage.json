{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Apex",
  "scopeName": "source.alpine",
  "patterns": [{ "include": "#script" }, { "include": "#style" }, { "include": "text.html.basic" }],
  "injections": {
    "L:source.alpine -comment -string.quoted -source.ts -source.css": {
      "patterns": [
        {
          "comment": "PascalCase component tag: <Button> / </Card> — colored like a type.",
          "match": "(</?)([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.begin.html" },
            "2": { "name": "support.class.component.alpine" }
          }
        },
        {
          "comment": "Any <template> tag — Alpine's structural element (x-for / x-if / slots).",
          "match": "(</?)(template)(?=[\\s/>])",
          "captures": {
            "1": { "name": "punctuation.definition.tag.begin.html" },
            "2": { "name": "keyword.control.flow.alpine" }
          }
        },
        {
          "comment": "Alpine x- directive WITH a value — swallows name + = + quoted value so the base HTML grammar never sees a dangling '=' (which it flags invalid).",
          "match": "(?<=[\\s\"'])(x-[a-zA-Z][\\w:.-]*)(=)(\"[^\"]*\"|'[^']*')",
          "captures": {
            "1": { "name": "keyword.control.directive.alpine" },
            "2": { "name": "punctuation.separator.key-value.html" },
            "3": { "name": "string.quoted.double.html" }
          }
        },
        {
          "comment": "Valueless x- directive: x-cloak, x-transition.",
          "match": "(?<=[\\s\"'])(x-[a-zA-Z][\\w:.-]*)",
          "name": "keyword.control.directive.alpine"
        }
      ]
    }
  },
  "repository": {
    "script": {
      "begin": "(<)(script)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "keyword.control.flow.alpine" },
        "3": {
          "name": "meta.tag.attributes.alpine",
          "patterns": [
            { "match": "\\b(server|client)\\b", "name": "storage.modifier.apex" },
            {
              "match": "\\b(lang)\\b(=)(\"[^\"]*\")",
              "captures": {
                "1": { "name": "entity.other.attribute-name.html" },
                "3": { "name": "string.quoted.double.html" }
              }
            }
          ]
        },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(script)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "keyword.control.flow.alpine" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "source.ts",
      "patterns": [{ "include": "source.ts" }]
    },
    "style": {
      "begin": "(<)(style)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "keyword.control.flow.alpine" },
        "3": {
          "name": "meta.tag.attributes.alpine",
          "patterns": [{ "match": "\\b(scoped)\\b", "name": "storage.modifier.apex" }]
        },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(style)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "keyword.control.flow.alpine" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "source.css",
      "patterns": [{ "include": "source.css" }]
    }
  }
}
