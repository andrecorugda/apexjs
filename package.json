{
  "name": "apexjs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Apex JS — the full-stack meta-framework for Alpine.js",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "prepare": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm -r --parallel --filter \"./packages/*\" dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter apex-e2e test:e2e",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "docs:uikit": "node scripts/build-uikit.mjs && pnpm dlx @tailwindcss/cli@4 -i docs/uikit.input.css -o docs/uikit.css --minify",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@changesets/cli": "^2.27.11",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "drizzle-orm": ">=0.45.2"
    }
  }
}
