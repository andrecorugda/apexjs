{
  "name": "apexjs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Apex JS — the full-stack meta-framework for Alpine.js",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm -r --parallel --filter \"./packages/*\" dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter spike test:e2e",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "^2.27.11",
    "@types/node": "^26",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
